# Copy to `.env` for local dev, or set these as environment variables in your host.

# MongoDB connection string.
#  - Local dev:   mongodb://localhost:27017
#  - Production:  mongodb+srv://<user>:<pass>@<cluster>.xxxxx.mongodb.net  (MongoDB Atlas)
MONGO_URL=mongodb://localhost:27017

# Database name within the Mongo instance.
DB_NAME=baddy_club

# Public base URL of the deployed app (used for absolute links).
#  - Local:       http://localhost:3000
#  - Production:  https://your-app.vercel.app
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Allowed CORS origins (comma-separated, or * for all).
CORS_ORIGINS=*

# Comma-separated list of emails granted admin-dashboard access (/admin).
# Admins sign in with the normal passwordless flow; matching emails unlock admin APIs.
ADMIN_EMAILS=admin@baddy.com
